## Visual Studio / .NET .gitignore

# Visual Studio cache/options directory (THIS is what caused your commit to fail)
.vs/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET / build artifacts
*.dll
*.exe
*.pdb
project.lock.json
project.fragment.lock.json
artifacts/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
[Cc]overage*/

# ASP.NET Core
appsettings.*.local.json
*.dev.json

# Secrets — never commit these (use User Secrets / env vars instead)
secrets.json
*.pfx
*.key

# Rider / JetBrains
.idea/
*.sln.iml

# VS Code
.vscode/

# macOS / Windows OS files
.DS_Store
Thumbs.db
desktop.ini
